# ============================================================
# fetchsys — environment variable reference
# Copy this file to .env and fill in values on your machine.
# .env is gitignored — NEVER commit secrets.
# ============================================================

# --------------- Search providers ---------------
# Waterfall: searxng → duckduckgo → brave → bing → serper
# DuckDuckGo and Bing are free HTML-scrape providers (no key needed).

# Tier 1 — SearXNG (self-hosted via Docker — JSON API enabled)
# Setup (one-time):
#   1. docker run -d -p 8888:8080 --name searxng searxng/searxng
#   2. Find the config volume:  docker inspect searxng | grep -i source
#   3. Edit settings.yml → add "json" under search.formats
#   4. docker restart searxng
# To restart later: docker start searxng
SEARXNG_URL=http://localhost:8888

# Tier 2 — DuckDuckGo (HTML scrape, no key)
# Enabled automatically — no config needed.

# Tier 3 — Brave Search API (2000 free queries/month — https://api-dashboard.search.brave.com/)
# Uncomment and fill in when you have a key:
# BRAVE_API_KEY=your_brave_api_key_here

# Tier 4 — Bing (HTML scrape, no key)
# Enabled automatically — no config needed.

# Tier 5 — Serper.dev (optional, paid — https://serper.dev/)
# SERPER_API_KEY=your_serper_api_key_here

# --------------- LLM providers ---------------
# Waterfall: google_gemini → groq → openrouter → ollama → openai → fallback
# Set the key(s) for the provider(s) you want to use. Providers without keys are skipped.

# Tier 1 — Google Gemini (free tier available — https://ai.google.dev/)
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Tier 2 — Groq (fast inference, generous free tier — https://console.groq.com/)
GROQ_API_KEY=your_groq_api_key_here

# Tier 3 — OpenRouter (aggregates many providers — https://openrouter.ai/)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-4o-mini

# Tier 4 — Ollama (local, no key required)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Tier 5 — OpenAI-compatible (OpenAI, Azure, LM Studio, etc.)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-4o-mini

# --------------- Reader ---------------

# Jina Reader API key (free: 1M tokens/month — https://jina.ai/reader/)
# Omit to use the free unauthenticated tier (lower rate limits).
# JINA_API_KEY=your_jina_api_key_here

# --------------- Behaviour overrides ---------------

# Number of top search results to read and fact-check (default: 5)
FETCHSYS_TOP_N=5

# Minimum search quality score before falling back (default: 0.3)
FETCHSYS_MIN_QUALITY=0.3

# Emit logs as JSON (useful in pipelines; default: false)
# FETCHSYS_LOG_JSON=true

# Path to custom TOML config file (optional)
# FETCHSYS_CONFIG=config/my-override.toml

# Enable verbose (debug) logging
# RUST_LOG=fetchsys=debug
